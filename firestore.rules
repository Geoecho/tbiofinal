rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for auth
    function isAdmin() {
      // In a real app, you'd check request.auth.uid against an admin list, 
      // or check request.auth.token.admin == true.
      // Since this app uses a simple passcode check from a doc, 
      // actual security should use Firebase Authentication!
      return request.auth != null; 
    }

    // Public read access to everything
    match /{document=**} {
      allow read: if true;
    }

    // Stories / Initiatives
    match /stories/{storyId} {
      // Anyone can increment likes by exactly 1
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['defaultLikes'])
                    && request.resource.data.defaultLikes == resource.data.defaultLikes + 1;
      
      // Only authenticated admins can create, edit, or delete stories
      allow create, update, delete: if isAdmin();
    }

    // Events
    match /events/{eventId} {
      allow create, update, delete: if isAdmin();
    }
    
    // Admin Config
    match /admin_config/{docId} {
      // Hide passcode from public
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
